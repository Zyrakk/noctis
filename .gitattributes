# Normalize all text files to LF in the repository.
* text=auto

# Source and config files: always LF.
*.go text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.html text eol=lf
*.css text eol=lf
*.svg text eol=lf
*.tmpl text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary

# Built dashboard bundles are committed artifacts — opaque to diff/merge,
# never normalized.
internal/dashboard/static/assets/* binary
