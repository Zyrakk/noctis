apiVersion: v1
kind: Secret
metadata:
  name: noctis-secrets
  namespace: noctis
  labels:
    app.kubernetes.io/name: noctis
    app.kubernetes.io/component: secrets
    app.kubernetes.io/part-of: noctis
type: Opaque
stringData:
  # =========================================================
  # REQUIRED — Core functionality breaks without these
  # =========================================================

  # PostgreSQL password (must match postgres.yaml)
  NOCTIS_DB_PASSWORD: "change-me-to-a-strong-password"

  # PostgreSQL DSN (constructed from the password above)
  NOCTIS_DB_DSN: "postgres://noctis:change-me-to-a-strong-password@noctis-postgres.noctis.svc:5432/noctis?sslmode=disable"

  # GLM-5 API key (ZhipuAI) — powers Summarizer, IOC Extractor, Entity Extractor, Librarian
  # Get at: https://open.bigmodel.cn
  NOCTIS_LLM_API_KEY: "your-glm-api-key-here"

  # Groq API key — powers Classifier (fast, free tier)
  # Get at: https://console.groq.com (no credit card required)
  NOCTIS_GROQ_API_KEY: "your-groq-api-key-here"

  # Google Gemini API key — powers Analyst, Brief Generator, Query Engine
  # Get at: https://aistudio.google.com (requires billing account for 3.1 Pro)
  # If omitted, Brain falls back to GLM-5 (lower reasoning quality)
  NOCTIS_GEMINI_API_KEY: "your-gemini-api-key-here"

  # Dashboard authentication key (any strong random string)
  # Required when dashboard.enabled: true
  NOCTIS_DASHBOARD_API_KEY: "generate-a-random-string-here"

  # =========================================================
  # TELEGRAM — Required if sources.telegram.enabled: true
  # =========================================================

  # Get API credentials at: https://my.telegram.org/apps
  NOCTIS_TELEGRAM_API_ID: ""
  NOCTIS_TELEGRAM_API_HASH: ""
  NOCTIS_TELEGRAM_PHONE: ""
  # 2FA password (leave empty if 2FA is not enabled)
  NOCTIS_TELEGRAM_PASSWORD: ""

  # =========================================================
  # OPTIONAL — Features degrade gracefully without these
  # =========================================================

  # AbuseIPDB API key — enriches IP-type IOCs (1,000 lookups/day free)
  # Get at: https://www.abuseipdb.com/account/api
  # If omitted, IP enrichment is skipped
  NOCTIS_ABUSEIPDB_KEY: ""

  # VirusTotal API key — enriches IPs, domains, hashes (500 lookups/day free)
  # Get at: https://www.virustotal.com/gui/my-apikey
  # If omitted, VT enrichment is skipped
  NOCTIS_VT_KEY: ""

  # NIST NVD API key — increases NVD rate limit from 5 to 50 req/30s
  # Get at: https://nvd.nist.gov/developers/request-an-api-key (free)
  # If omitted, vulnerability ingestion still works, just slower
  NOCTIS_NVD_API_KEY: ""

  # Pastebin PRO API key (optional — required for paste collector)
  # NOCTIS_PASTEBIN_API_KEY: ""
